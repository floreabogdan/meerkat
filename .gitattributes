# Normalize line endings in the repo, and force LF for the files that must be
# LF on the systems they run on — the package maintainer scripts (Debian/RPM/
# Alpine), the build script, and the systemd units.
* text=auto
*.sh text eol=lf
*.service text eol=lf
*.path text eol=lf

# Binary assets: never touched, never diffed as text.
*.png binary
*.woff2 binary
*.mmdb binary

# The alert fixture is real captured data, not something to review line by line.
internal/eve/evetest/testdata/alerts.jsonl -diff linguist-generated
